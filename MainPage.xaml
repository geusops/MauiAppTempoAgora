<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppTempoAgora.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Button Text="Qualquer coisa" Clicked="Button_Clicked_1"/>
            <Label x:Name="lbl_coords" />

            <Entry x:Name="txt_cidade" />
            <Button Text="Buscar" Clicked="Button_Clicked"/>

            <Label x:Name="lbl_res" />
            <Label x:Name="lbl_resp" />

            <WebView x:Name="wv_mapa" HeightRequest="500"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
